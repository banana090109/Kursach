@model BuildStore.Models.User

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="card">

                <div class="card-body">

                    <h1 class="mb-4">
                        Profile
                    </h1>

                    <hr />

                    <h4>
                        Email
                    </h4>

                    <p>
                        @Model.Email
                    </p>

                    <h4>
                        Phone Number
                    </h4>

                    <p>
                        @(Model.PhoneNumber ?? "Not specified")
                    </p>

                    <h4>
                        Registered
                    </h4>

                    <p>
                        @Model.CreatedAt
                    </p>

                    <hr />

                    <h4>
                        Total Orders
                    </h4>

                    <p>
                        @ViewBag.TotalOrders
                    </p>

                    <h4>
                        Total Spent
                    </h4>

                    <p>
                        @ViewBag.TotalSpent $
                    </p>

                </div>

            </div>

        </div>

    </div>

</div>